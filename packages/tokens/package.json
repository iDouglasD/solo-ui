{
  "name": "@solo-ui/tokens",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@solo-ui/ts-config": "workspace:*",
    "tsup": "latest",
    "typescript": "latest",
    "@biomejs/biome": "latest"
  }
}
