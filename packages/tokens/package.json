{
  "name": "@solo-ds/tokens",
  "version": "1.0.2",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@solo-ds/ts-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "@biomejs/biome": "^2.4.8"
  }
}
